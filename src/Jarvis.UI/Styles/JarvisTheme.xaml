<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- J.A.R.V.I.S Iron-Man HUD palette: deep navy + arc-reactor cyan + gold accents -->
    <Color x:Key="BgDeepColor">#FF050B14</Color>
    <Color x:Key="BgPanelColor">#FF0B1828</Color>
    <Color x:Key="BgPanelAccentColor">#FF112338</Color>
    <Color x:Key="ArcCyanColor">#FF22D3EE</Color>
    <Color x:Key="ArcCyanDimColor">#FF0E7C8F</Color>
    <Color x:Key="GoldColor">#FFFFB347</Color>
    <Color x:Key="DangerColor">#FFE94560</Color>
    <Color x:Key="TextPrimaryColor">#FFE2F5FA</Color>
    <Color x:Key="TextMutedColor">#FF7FA0B5</Color>

    <SolidColorBrush x:Key="BgDeep" Color="{StaticResource BgDeepColor}"/>
    <SolidColorBrush x:Key="BgPanel" Color="{StaticResource BgPanelColor}"/>
    <SolidColorBrush x:Key="BgPanelAccent" Color="{StaticResource BgPanelAccentColor}"/>
    <SolidColorBrush x:Key="ArcCyan" Color="{StaticResource ArcCyanColor}"/>
    <SolidColorBrush x:Key="ArcCyanDim" Color="{StaticResource ArcCyanDimColor}"/>
    <SolidColorBrush x:Key="Gold" Color="{StaticResource GoldColor}"/>
    <SolidColorBrush x:Key="Danger" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="TextPrimary" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextMuted" Color="{StaticResource TextMutedColor}"/>

    <FontFamily x:Key="DisplayFont">Rajdhani, Segoe UI, Arial</FontFamily>
    <FontFamily x:Key="BodyFont">Consolas, Cascadia Mono, Courier New</FontFamily>

    <!-- Window base -->
    <Style x:Key="JarvisWindow" TargetType="Window">
        <Setter Property="Background" Value="{StaticResource BgDeep}"/>
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
    </Style>

    <!-- Sharp-edged "HUD" button -->
    <Style x:Key="HudButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource ArcCyan}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ArcCyanDim}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="18,10"/>
        <Setter Property="FontFamily" Value="{StaticResource DisplayFont}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Polygon Stroke="{TemplateBinding BorderBrush}"
                                 StrokeThickness="{TemplateBinding BorderThickness}"
                                 Fill="{TemplateBinding Background}"
                                 Points="0,0 100,0 110,10 110,30 100,40 0,40"
                                 Stretch="Fill"/>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Margin="{TemplateBinding Padding}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#22D3EE22"/>
                <Setter Property="Foreground" Value="{StaticResource Gold}"/>
                <Setter Property="BorderBrush" Value="{StaticResource Gold}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- TextBox in HUD style -->
    <Style x:Key="HudTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource BgPanelAccent}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        <Setter Property="CaretBrush" Value="{StaticResource ArcCyan}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ArcCyanDim}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="FontFamily" Value="{StaticResource BodyFont}"/>
        <Setter Property="FontSize" Value="14"/>
    </Style>

    <Style x:Key="DisplayText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource DisplayFont}"/>
        <Setter Property="Foreground" Value="{StaticResource ArcCyan}"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

</ResourceDictionary>
